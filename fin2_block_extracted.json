  <text x=\"60\" y=\"115\" class=\"label-box-text\">Savings A/C No : <tspan class=\"value-text\">4050123</tspan></text>\n        \n        <rect x=\"470\" y=\"90\" width=\"230\" height=\"40\" class=\"inner-box\" />\n        <text x=\"480\" y=\"115\" class=\"label-box-text\">Date : <tspan class=\"value-text\">10.01.2025</tspan></text>\n\n        <text x=\"80\" y=\"175\" class=\"body-text\">Pay to : <tspan class=\"underline-text\">  Mr. Saimon  </tspan> or Bearer</text>\n        <line x1=\"140\" y1=\"180\" x2=\"480\" y2=\"180\" class=\"dotted-line\" />\n        \n        <text x=\"80\" y=\"215\" class=\"body-text\">Taka (in words) : <tspan class=\"underline-text\">  Ten Thousand Only  </tspan></text>\n        <line x1=\"210\" y1=\"220\" x2=\"480\" y2=\"220\" class=\"dotted-line\" />\n\n        <rect x=\"80\" y=\"245\" width=\"220\" height=\"45\" class=\"cheque-border\" />\n        <text x=\"95\" y=\"274\" class=\"amount-num\">Tk = 10,000/-</text>\n\n        <line x1=\"570\" y1=\"270\" x2=\"680\" y2=\"270\" class=\"dotted-line\" />\n        <text x=\"625\" y=\"290\" class=\"signature-text\">Sumi</text>\n        <text x=\"625\" y=\"308\" class=\"signature-text\">Signature</text>\n    </g>\n</svg>",
