C No :</text>\n        <text x=\"610\" y=\"115\" class=\"value-text\">23458</text>\n        \n        <text x=\"548\" y=\"145\" class=\"label-text\">Date :</text>\n        <text x=\"610\" y=\"145\" class=\"value-text\">25-01-2025</text>\n\n        <text x=\"120\" y=\"195\" class=\"body-text\">Pay to  <tspan font-weight=\"bold\" style=\"text-decoration: underline;\"> Mr. Faruk </tspan>  or Bearer</text>\n        <text x=\"120\" y=\"240\" class=\"body-text\">the sum of  <tspan font-weight=\"bold\" style=\"text-decoration: underline;\"> One Lakh Twenty Thousand Taka Only </tspan></text>\n\n        <rect x=\"40\" y=\"270\" width=\"240\" height=\"50\" class=\"cheque-border\" />\n        <text x=\"55\" y=\"302\" class=\"amount-num\">TK : 1,20,000/-</text>\n\n        <line x1=\"620\" y1=\"290\" x2=\"730\" y2=\"290\" class=\"dotted-line\" />\n        <text x=\"675\" y=\"310\" class=\"signature-text\">Pranto</text>\n        <text x=\"675\" y=\"328\" class=\"signature-text\">Signature</text>\n    </g>\n\n    <text x=\"400\" y=\"810\" class=\"main-title\">Figure No-2</text>\n</svg>",
