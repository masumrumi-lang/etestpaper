    },
    {
        "id": 1556,
        "text": "<p>Profitless sales of 2,00,000 TK will be included in the Income Statement as\u2014\n\ni. Deducted from Purchase\n\nii. Deducted as Expense\n\niii. Deducted from Sales</p>",
        "meta": "Jashore  Board - 2017",
