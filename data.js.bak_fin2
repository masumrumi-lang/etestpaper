    {
        id: 20,
        stem: "<p>Meghna Co. bought a 5,00,000 machine on Jan 1, 2020. Costs: Transport 60,000, Installation 90,000. Life 10 years, salvage 50,000. RB Method is used. Year ends Dec 31.</p>",
        meta: "Comilla Govt. College, Comilla · 2025",
        type: "college",
        questions: [
            {
                label: "a",
                text: "Determine the depreciation rate using the Reducing Balance method.",
                answer: "<p class='font-mono text-xs'>Rate = (100 / 10) &times; 2 = <strong>20%</strong>.</p>"
            },
            {
                label: "b",
                text: "Provide journal entries for the first two years.",
                answer: "<div class='space-y-2 text-xs font-mono'><p>Cost = 5,00,000 + 60,000 + 90,000 = <strong>6,50,000</strong>.</p><p>2020 Dep = 6,50,000 &times; 20% = <strong>1,30,000</strong>.</p><p>2021 Dep = (6,50,000 - 1,30,000) &times; 20% = <strong>1,04,000</strong>.</p><div class='overflow-x-auto'><p class='font-semibold underline text-center'>Meghna Co. &mdash; Journal Entries</p><table class='w-full text-[10px] border-collapse border border-gray-300'><thead><tr class='bg-gray-100'><th class='border p-1'>Date</th><th class='border p-1'>Account Title &amp; Explanation</th><th class='border p-1'>Ref</th><th class='border p-1'>Debit (Tk)</th><th class='border p-1'>Credit (Tk)</th></tr></thead><tbody><tr><td class='border p-1'>2020<br>Jan. 1</td><td class='border p-1'>Machine A/C<br>&nbsp;&nbsp;&nbsp;&nbsp;Bank A/C<br><em>(Machine purchased &amp; installed)</em></td><td class='border p-1'></td><td class='border p-1 text-right'>6,50,000</td><td class='border p-1 text-right'><br>6,50,000</td></tr><tr><td class='border p-1'>Dec. 31</td><td class='border p-1'>Depreciation Expense A/C<br>&nbsp;&nbsp;&nbsp;&nbsp;Accumulated Depreciation A/C<br><em>(Dep. charged @ 20% RB)</em></td><td class='border p-1'></td><td class='border p-1 text-right'>1,30,000</td><td class='border p-1 text-right'><br>1,30,000</td></tr><tr><td class='border p-1'>&quot; &ndash;31</td><td class='border p-1'>Income Summary A/C<br>&nbsp;&nbsp;&nbsp;&nbsp;Depreciation Expense A/C<br><em>(Dep. expense closed)</em></td><td class='border p-1'></td><td class='border p-1 text-right'>1,30,000</td><td class='border p-1 text-right'><br>1,30,000</td></tr><tr><td class='border p-1'>2021<br>Dec. 31</td><td class='border p-1'>Depreciation Expense A/C<br>&nbsp;&nbsp;&nbsp;&nbsp;Accumulated Depreciation A/C<br><em>(Dep. charged @ 20% RB)</em></td><td class='border p-1'></td><td class='border p-1 text-right'>1,04,000</td><td class='border p-1 text-right'><br>1,04,000</td></tr><tr><td class='border p-1'>&quot; &ndash;31</td><td class='border p-1'>Income Summary A/C<br>&nbsp;&nbsp;&nbsp;&nbsp;Depreciation Expense A/C<br><em>(Dep. expense closed)</em></td><td class='border p-1'></td><td class='border p-1 text-right'>1,04,000</td><td class='border p-1 text-right'><br>1,04,000</td></tr></tbody></table></div></div>"
            },
