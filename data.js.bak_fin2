        ],
        "correctAnswer": 1,
        "explanation": "<p>N<code>PV</code> increases when the denominator (rate) decreases or the numerator (cash flow) increases.</p>",
        "id": 4826
    },
    {
        "text": "<p>Which project should be accepted?</p>",
        "meta": "Dinajpur Board · 2025",
        "type": "board",
