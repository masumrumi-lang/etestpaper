    },
    {
        "id": 1604,
        "text": "<p>Opening Stock 1,00,000 TK; Purchase 1,55,000 TK; Purchase Return 3,00,0; Purchase Discount 2,000 TK; Wages & Salary 3,000 TK; Machine Carriage 4,000 TK; Import Duty on Machine 1,000 TK; Closing Stock 90,000 TK (Market Value); Sales 2,05,000 TK. What is the Net Purchase?</p>",
        "meta": "Jashore Board - 2016",
        "type": "board",
