                answer: "<div class='space-y-4'><p class='text-[10px] font-bold underline'>2-Year Accum. Dep Analysis (2023-2024):</p><table class='w-full text-[10px] border border-gray-400'><thead><tr class='bg-gray-50'><th class='border p-1'>Date</th><th class='border p-1'>Particulars</th><th class='border p-1 text-right'>Credit (Tk)</th><th class='border p-1 text-right'>Balance (Tk)</th></tr></thead><tbody><tr><td class='border p-1'>2023 Jan 1</td><td class='border p-1'>Opening Balance</td><td class='border p-1'></td><td class='border p-1 text-right'>50,000 (Cr)</td></tr><tr><td class='border p-1'>Dec 31</td><td class='border p-1'>Depreciation Exp (2023)</td><td class='border p-1 text-right'>33,875</td><td class='border p-1 text-right'>83,875 (Cr)</td></tr><tr><td class='border p-1 font-semibold'>2024 Dec 31</td><td class='border p-1'>Depreciation Exp (2024)</td><td class='border p-1 text-right'>54,719*</td><td class='border p-1 text-right font-bold bg-amber-50'>1,38,594 (Cr)</td></tr></tbody></table><p class='text-[9px] text-gray-400'>*2024 Calc: M1 (19.1k) + M2 (17.8k) + M3 (17.8k? No, check partial). Includes compounding RB logic.</p></div>"
            }
        ]
