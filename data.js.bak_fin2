-r border-gray-200 dark:border-gray-700 last:border-r-0\">80,700 TK</td><td class=\"px-4 py-2 text-right text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\">50,500 TK</td><td class=\"px-4 py-2 text-right text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\">10,000 TK</td><td class=\"px-4 py-2 text-left text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\">?</td><td class=\"px-4 py-2 text-left text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\">?</td></tr><tr class=\"bg-white dark:bg-gray-900\"><td class=\"px-4 py-2 text-left text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\">&#x27;Q&#x27; Traders</td><td class=\"px-4 py-2 text-right text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\">55,000 TK</td><td class=\"px-4 py-2 text-left text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\">?</td><td class=\"px-4 py-2 text-right text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\">18,500 TK</td><td class=\"px-4 py-2 text-right text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\">15,500 TK</td><td class=\"px-4 py-2 text-left text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\">?</td></tr></table></div>",
        "meta": "Cumilla  Board - 2021",
        "type": "board",
        "options": [
