    },
    {
        "id": 1287,
        "text": "<p>If 150 Unused Stationery is recorded\u2014\n\ni. Closing stock overstated\n\nii. Net profit decreases\n\niii. Stationery Expense decreases</p>",
        "meta": "Sylhethet  Board - 2025",
        "type": "board",
