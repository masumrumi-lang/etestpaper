-200 dark:border-gray-700 last:border-r-0\">500</td><td class=\"px-4 py-2 text-left text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\"></td><td class=\"px-4 py-2 text-left text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\"></td><td class=\"px-4 py-2 text-left text-sm text-gray-700 dark:text-gray-300 border-r border-gray-200 dark:border-gray-700 last:border-r-0\"></td></tr></table></div>",
