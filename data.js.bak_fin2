        "options": [
            "Arithmetical Accuracy",
            "Profit calculation",
            "Asset valuation",
            "Liability check"
        ],
        "correctAnswer": 0,
        "explanation": "<p>Trial Balance specifically checks math, supporting the Reliability of records.</p>"
    },
    {
