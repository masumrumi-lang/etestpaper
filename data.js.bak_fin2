        "id": 4235
    },
    {
        "text": "<p>A loan installment contains—\n\ni. Interest amount\n\nii. Total interest amount\n\niii. Principal repayment</p>",
        "meta": "Sylhet · 2015",
        "type": "board",
        "options": [
