        "id": 4063
    },
    {
        "text": "<p>Mr. Rahim deposits TK 50,000 for 270 days at 8% interest. How much will he receive at maturity?</p>",
        "meta": "Ctg · 2022",
        "type": "board",
        "options": [
            "52,970",
