        "id": 4079
    },
    {
        "text": "<p>What is another name for the Future Value (<code>FV</code>) of money?</p>",
        "meta": "Dinajpur · 2022",
        "type": "board",
        "options": [
            "Discounted Value",
            "Cash Value",
            "Initial Value",
            "Terminal Value"
