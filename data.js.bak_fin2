    },
    {
        "id": 1552,
        "text": "<p>How is Prepaid Expense considered for a business?</p>",
        "meta": "Jashore  Board - 2017",
        "type": "board",
        "options": [
            "Income",
            "Expense",
            "Asset",
            "Liability"
        ],
        "correctAnswer": 2,
        "explanation": "<p>Prepaid expenses provide future benefits, hence they are assets.</p>"
    },
    {
        "id": 1553,
        "text": "<p>Adjusted in the Income Statement\u2014\n\ni. Addl. Capital\n\nii. Product Drawing\n\niii. Bad Debt</p>",
        "meta": "Jashore  Board - 2017",
