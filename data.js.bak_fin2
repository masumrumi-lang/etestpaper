        ],
        "correctAnswer": 2,
        "explanation": "<p>Positive N<code>PV</code> indicates that the project is profitable and should be accepted.</p>",
        "id": 4928
    },
    {
        "text": "<p>If discount rate > <code>IRR</code>, what will be the N<code>PV</code>?</p>",
        "meta": "Comilla Board · 2022",
