        "meta": "Cantonment College, Jessore · 2026",
        "type": "college"
    },
    {
        "id": "fin1-ch5-short-a-035",
        "text": "What is EOQ?",
        "answer": "Economic Order Quantity (EOQ) is the order size that minimizes the total annual cost of ordering and holding inventory.",
        "meta": "Ispahani Public School, Comilla · 2026",
