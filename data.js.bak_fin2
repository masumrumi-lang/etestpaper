        "id": 4216
    },
    {
        "text": "<p>What is the receipt or payment of equal cash flows for an infinite period called?</p>",
        "meta": "Dhaka · 2016",
        "type": "board",
        "options": [
            "Payable Annuity",
            "Receivable Annuity",
            "Perpetuity",
            "Ordinary Annuity"
