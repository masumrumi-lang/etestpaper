    },
    {
        "id": 1559,
        "text": "<p>Reasons for decrease in business capital\u2014\n\ni. Increase in Opening. Expense\n\nii. Net loss in current year\n\niii. Increase in sales</p>",
        "meta": "Chittagong - 2017",
        "type": "board",
        "options": [
            "i & ii",
            "i & iii",
            "ii & iii",
