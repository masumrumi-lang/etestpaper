    },
    {
        "id": 1570,
        "text": "<p>Accounts Receivable 60 TKkTK, Bad debt 2 TKkTK. Create 5 TK\\%TK Bad Debt Provision. Provision amount?</p>",
        "meta": "Dinajpur  Board - 2017",
        "type": "board",
        "options": [
            "3,100 TK",
